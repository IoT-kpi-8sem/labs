{
  "uid": "kpi-tech",
  "title": "KPI Labs — Tech (RPS, Latency, MQTT, DB)",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["kpi-labs", "tech"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets up",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}} ({{instance}})", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Store HTTP RPS by route",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Store HTTP latency p50/p95/p99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DB queries/sec by action",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model, action, status) (rate(db_queries_total[1m]))",
          "legendFormat": "{{model}}.{{action}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DB query latency p95 by action",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model, action) (rate(db_query_duration_seconds_bucket[1m])))",
          "legendFormat": "{{model}}.{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "WebSocket connections",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "websocket_connections", "legendFormat": "active", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "WebSocket events/sec",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (event, direction) (rate(websocket_messages_total[1m]))",
          "legendFormat": "{{event}} ({{direction}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Agent MQTT connected",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "agent_mqtt_connected", "refId": "A" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Pipeline throughput (msg/s) — Agent → Edge → Hub → Store",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(agent_messages_published_total[1m]))", "legendFormat": "agent published", "refId": "A" },
        { "expr": "sum(rate(edge_messages_processed_total[1m]))", "legendFormat": "edge processed", "refId": "B" },
        { "expr": "sum(rate(hub_road_data_received_total[1m]))", "legendFormat": "hub received", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Edge → Hub p95 latency",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(edge_hub_send_duration_seconds_bucket[1m])))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Hub → Store p95 latency",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(hub_store_call_duration_seconds_bucket[1m])))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Agent MQTT publish p95",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, topic) (rate(agent_publish_duration_seconds_bucket[1m])))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Mosquitto messages/sec",
      "gridPos": { "x": 0, "y": 36, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(broker_messages_received[1m])", "legendFormat": "received", "refId": "A" },
        { "expr": "rate(broker_messages_sent[1m])", "legendFormat": "sent", "refId": "B" },
        { "expr": "broker_load_publish_received_1min", "legendFormat": "publish received (1m avg)", "refId": "C" },
        { "expr": "broker_load_publish_sent_1min", "legendFormat": "publish sent (1m avg)", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Mosquitto clients connected",
      "gridPos": { "x": 8, "y": 36, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "broker_clients_connected", "refId": "A" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Mosquitto bytes/sec",
      "gridPos": { "x": 8, "y": 40, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(broker_bytes_received[1m])", "legendFormat": "in", "refId": "A" },
        { "expr": "rate(broker_bytes_sent[1m])", "legendFormat": "out", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Postgres tx/sec",
      "gridPos": { "x": 16, "y": 36, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{datname=\"lab-2-store\"}[1m]))",
          "legendFormat": "{{datname}} commits",
          "refId": "A"
        },
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{datname=\"lab-2-store\"}[1m]))",
          "legendFormat": "{{datname}} rollbacks",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Postgres backends",
      "gridPos": { "x": 0, "y": 44, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"lab-2-store\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } }
    }
  ]
}
